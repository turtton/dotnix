				}
			]
		},
		"quick": {
			"model": "cursor-acp/composer-2.5",
			"fallback_models": [
				{
					"model": "opencode-go/minimax-m2.7"
				}
			]
		},
		"unspecified-low": {
			"model": "cursor-acp/composer-2.5",
			"fallback_models": [
				{
					"model": "opencode-go/kimi-k2.6"
				}
			]
		},
		"unspecified-high": {
			"model": "opencode-go/kimi-k2.6",
			"fallback_models": [
				{
					"model": "openai/gpt-5.5",
