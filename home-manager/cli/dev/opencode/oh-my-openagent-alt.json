		"writing": {
			"model": "opencode-go/kimi-k2.6",
			"fallback_models": [
				{
					"model": "cursor-acp/composer-2.5"
				}
			]
		}
	},
	"tmux": {
		"enabled": true
	},
	"team_mode": {
		"enabled": true,
		"max_parallel_members": 4,
		"tmux_visualization": true
	},
	"background_task": {
		"circuitBreaker": {
			"windowSize": 100,
			"repetitionThresholdPercent": 90,
			"maxToolCalls": 400
		}
	},
	"skills": {
		"sources": [
			"@OPENCODE_CONFIG_DIR@/skill/final-review",
			"@OPENCODE_CONFIG_DIR@/skill/git-commit"
		]
	}
}
