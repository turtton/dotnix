{
	"$schema": "https://opencode.ai/config.json",
	"plugin": [
		"oh-my-openagent",
		"opencode-comments-plugin",
		"@simonwjackson/opencode-direnv",
		"opencode-wakatime"
	],
	"agent": {
		"title": {
			"model": "opencode-go/minimax-m2.7"
		}
	},
	"provider": {
		"cursor-api": {
			"name": "Cursor",
			"npm": "@ai-sdk/openai-compatible",
			"options": {
				"baseURL": "http://127.0.0.1:8787/v1"
			},
			"models": {
				"composer-2.5": {
					"name": "Composer 2.5",
					"cost": {
						"input": 0.5,
						"output": 2.5,
						"cache_read": 0.2
					}
				},
				"composer-2.5-fast": {
					"name": "Composer 2.5 Fast",
					"cost": {
						"input": 3,
						"output": 15,
						"cache_read": 0.5
					}
				},
				"gpt-5.5": {
					"name": "GPT-5.5",
					"reasoning": true,
					"variants": {
						"xhigh": {},
						"high": {},
						"medium": {}
					}
				}
			}
		},
		"CrofAI": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "CrofAI",
			"options": {
				"baseURL": "https://crof.ai/v1"
			},
			"models": {
				"deepseek-v4-pro": {
					"name": "DeepSeek V4 Pro",
					"limit": {
						"context": 1000000,
						"output": 131072
					},
					"cost": {
						"input": 0.35,
						"output": 0.8,
						"cache_read": 0.003
					}
				},
				"deepseek-v4-flash": {
					"name": "DeepSeek V4 Flash",
