{
	"$schema": "https://opencode.ai/config.json",
	"plugin": [
		"@tarquinen/opencode-dcp",
		"oh-my-openagent",
		"opencode-comments-plugin",
		"@simonwjackson/opencode-direnv",
		"opencode-wakatime"
	],
	"agent": {
		"title": {
			"model": "openai/gpt-5.4-nano"
		}
	},
	"provider": {
		"cursor-api": {
			"name": "Cursor",
			"npm": "@ai-sdk/openai-compatible",
			"options": {
				"baseURL": "http://127.0.0.1:8787/v1"
			}
		}
	}
}
