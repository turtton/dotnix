{
	"$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",
	"agents": {
		"sisyphus": {
			"model": "openai/gpt-5.5",
			"variant": "medium"
		},
		"hephaestus": {
			"model": "openai/gpt-5.5",
			"variant": "medium"
		},
		"oracle": {
			"model": "openai/gpt-5.5",
			"variant": "high",
			"tools": {
				"skill": false
			}
		},
		"momus": {
			"model": "openai/gpt-5.5",
			"variant": "xhigh"
		},
		"metis": {
			"model": "openai/gpt-5.5",
			"variant": "high"
		},
		"prometheus": {
			"model": "openai/gpt-5.5",
			"variant": "high"
		},
		"atlas": {
			"model": "cursor-api/composer-2.5-fast"
		},
		"sisyphus-junior": {
			"model": "cursor-api/composer-2.5-fast"
		},
		"explore": {
			"model": "openai/gpt-5.4-mini-fast"
		},
		"librarian": {
			"model": "openai/gpt-5.4-mini-fast"
		},
		"multimodal-looker": {
			"model": "openai/gpt-5.5",
			"variant": "medium"
		}
	},
	"categories": {
		"visual-engineering": {
			"model": "cursor-api/composer-2.5-fast"
		},
		"ultrabrain": {
			"model": "openai/gpt-5.5",
			"variant": "xhigh"
		},
		"deep": {
			"model": "openai/gpt-5.5",
			"variant": "medium",
			"fallback_models": [
				{
					"model": "cursor-api/composer-2.5-fast"
				}
			]
		},
		"artistry": {
			"model": "openai/gpt-5.5"
		},
		"quick": {
			"model": "openai/gpt-5.4-mini-fast"
		},
		"unspecified-low": {
			"model": "openai/gpt-5.3-codex"
		},
		"unspecified-high": {
			"model": "openai/gpt-5.5",
			"variant": "high"
		},
		"writing": {
			"model": "cursor-api/composer-2.5-fast"
		}
	},
	"tmux": {
		"enabled": true
	},
	"team_mode": {
		"enabled": true,
		"max_parallel_members": 4,
		"tmux_visualization": true
	},
	"background_task": {
		"circuitBreaker": {
			"windowSize": 100,
			"repetitionThresholdPercent": 90,
			"maxToolCalls": 400
		}
	},
	"skills": {
		"sources": [
			"@OPENCODE_CONFIG_DIR@/skill/final-review",
			"@OPENCODE_CONFIG_DIR@/skill/git-commit"
		]
	}
}
